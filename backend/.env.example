SUPABASE_URL=
SUPABASE_SERVICE_KEY=
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
FEEGOW_TOKEN=
WHATSAPP_NUMBER=5551995012315
PROPRIETARIA_NUMBER=55519XXXXXXXX

# Google Ads — preencher quando a conta estiver ativa
# Developer token: painel Google Ads > Ferramentas > Centro de API
# Client ID / Secret: Google Cloud Console > APIs > OAuth 2.0
# Refresh token: gerado via OAuth flow (google-auth-oauthlib ou oauth2l)
# Customer ID: ID da conta de anuncios (formato 123-456-7890, sem traco no .env)
# Login Customer ID: ID da conta MCC, se houver (deixar vazio se conta direta)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
